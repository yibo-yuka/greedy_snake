# ── Greedy Snake Backend — Environment Variables Example ──────────────────
# Copy this file to .env (development) or .env.prod (production)
# NEVER commit .env or .env.prod to git!

# Django settings
DJANGO_SETTINGS_MODULE=greedy_snake.settings.development
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-50-chars

# Debug mode (MUST be False in production)
DEBUG=True

# Allowed hosts (comma-separated)
# Production example: snake.yourdomain.duckdns.org,www.yourdomain.duckdns.org
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS — comma-separated allowed origins
# Add your GitHub Pages URL and DuckDNS domain
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8080,https://yibo-yuka.github.io

# Database
# Development: leave blank to use SQLite
# Production: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# PostgreSQL (for docker-compose)
POSTGRES_DB=greedy_snake
POSTGRES_USER=snake
POSTGRES_PASSWORD=snakepass_dev_change_in_prod
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (for caching and Phase 4 WebSocket)
REDIS_URL=redis://redis:6379/0

# DuckDNS domain (for production HTTPS)
# DUCKDNS_DOMAIN=your-name.duckdns.org
# DUCKDNS_TOKEN=your-duckdns-token
